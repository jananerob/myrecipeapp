<!DOCTYPE html>
<html>
  <head>
    <title>Co-Cook</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="bg-gray-50">
    <%= render 'shared/navbar' %>

    <%# 1. NOVÝ FLOATING BANNER %>
    <div class="fixed top-24 left-0 right-0 z-40 flex justify-center pointer-events-none">
      <div class="max-w-md w-full px-4 pointer-events-auto">
        <% flash.each do |type, message| %>
          <% 
            alert_classes = case type.to_sym
                            when :notice then "bg-green-50 border-green-500 text-green-800 shadow-lg shadow-green-900/5"
                            when :alert, :error then "bg-red-50 border-red-500 text-red-800 shadow-lg shadow-red-900/5"
                            else "bg-blue-50 border-blue-500 text-blue-800 shadow-lg shadow-blue-900/5"
                            end
            
            icon_path = case type.to_sym
                        when :notice then "M5 13l4 4L19 7"
                        else "M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                        end
          %>

          <div class="<%= alert_classes %> flex items-center p-4 mb-4 border-l-4 rounded-r-xl transform transition-all duration-500 hover:scale-102">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= icon_path %>" />
              </svg>
            </div>
            
            <div class="ml-3 font-medium text-sm">
              <%= message %>
            </div>

                  <button type="button" class="ml-auto -mx-1.5 -my-1.5 p-1.5 inline-flex h-8 w-8 hover:bg-white/50 rounded-lg transition" onclick="this.parentElement.remove()">
                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
                    </svg>
                  </button>
                </div>
              <% end %>
            </div>
          </div>

          <%# 2. HLAVNÝ OBSAH %>
          <main class="container mx-auto mt-10 px-4">
            <%= yield %>
          </main>
        </body>
      </html>